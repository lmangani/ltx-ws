    '                             f"but requested an effective batch size of {batch_size}.")\n',
    '\n',
    '        sampled_random = False\n',
    '        if latents is None:\n',
    '            if latent_path:\n',
    '                loaded_latents = self._load_initial_latent(latent_path, device, dtype)\n',
    '                if loaded_latents is not None:\n',
    '                    latents = loaded_latents\n',
    '                else:\n',
    '                    latents = randn_tensor(\n',
    '                        shape,\n',
    '                        generator=generator,\n',
    '                        device=device,\n',
    '                        dtype=dtype,\n',
    '                    )\n',
    '                    self._save_initial_latent(latent_path, latents)\n',
    '            else:\n',
    '                latents = randn_tensor(\n',
    '                    shape,\n',
    '                    generator=generator,\n',
    '                    device=device,\n',
    '                    dtype=dtype,\n',
