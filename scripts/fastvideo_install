    '            width // spatial_ratio,\n',
    '        )\n',
    '\n',
    '        if isinstance(generator, list) and len(generator) != batch_size:\n',
    '            raise ValueError(f"You have passed a list of generators of length {len(generator)}, "\n',
    '                             f"but requested an effective batch size of {batch_size}.")\n',
