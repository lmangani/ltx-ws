    '                sampled_random = True\n',
    '        else:\n',
    '            latents = latents.to(device)\n',
    '\n',
    '        batch.extra.pop("ltx2_i2v_anchor_latents", None)\n',
    '        if (\n',
    '            latent_path is None\n',
    '            and sampled_random\n',
    '            and batch.pil_image is not None\n',
    '            and self.vae is not None\n',
    '            and shape[2] > 1\n',
    '        ):\n',
    '            latents = self._blend_start_image_into_latents(\n',
    '                latents,\n',
