    '        if height % spatial_ratio != 0 or width % spatial_ratio != 0:\n',
    '            raise ValueError(f"Height and width must be divisible by {spatial_ratio} "\n',
    '                             f"but are {height} and {width}.")\n',
    '        shape = (\n',
    '            batch_size,\n',
