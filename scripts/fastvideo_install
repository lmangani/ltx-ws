LTX2_LATENT_I2V_BODY_NEW = "".join((
    '    def __init__(self, transformer, vae: Any | None = None) -> None:\n',
    '        super().__init__()\n',
    '        self.transformer = transformer\n',
    '        self.vae = vae\n',
    '\n',
    '    def forward(\n',
    '        self,\n',
    '        batch: ForwardBatch,\n',
    '        fastvideo_args: FastVideoArgs,\n',
    '    ) -> ForwardBatch:\n',
    '        latent_num_frames = (batch.num_frames -\n',
