#!/usr/bin/env python3
"""
Install FastVideo for videofentanyl (especially Apple Silicon / MPS).

Does the full sequence that upstream docs omit:
  1. Initialize the FastVideo git submodule (this repo layout). If the recorded commit is
     not available from the public FastVideo remote, submodule update may fail; an existing
     ``third_party/FastVideo`` checkout is still patched and the script prints the gitlink SHA.
  2. Patch pyproject.toml so ``fastvideo-kernel`` (Triton / Linux CUDA wheels only)
     is not required on macOS — MPS uses Torch SDPA and does not need it.
  3. Patch ``ltx2_denoising.py``: ``torch.autocast`` uses the active device (MPS/CUDA),
     not hard-coded ``cuda``; optional structured ``FV_PROGRESS_JSON`` log lines for
     ``videofentanylserver`` keepalives.
  4. Patch ``decoding.py``: decoded ``batch.output`` on CPU (MPS tensors cannot be
     sent over multiprocessing pipes).
  5. Patch ``multiproc_executor.py``: sanitize tensors in ``execute_forward`` replies
     before ``pipe.send`` (belt-and-suspenders for MPS IPC).
  6. Patch LTX-2 image-to-video: ``ltx2_pipeline.py`` passes the VAE into latent preparation;
     ``ltx2_latent_preparation.py`` VAE-encodes ``image_path`` / ``pil_image`` into the first
     latent slice when sampling random latents; ``ltx2_denoising.py`` pins that slice each step.
  7. Run ``uv pip install -e`` (or ``python -m pip`` if uv is missing).

Run from the videofentanyl repo root (recommended):

  ./scripts/fastvideo_install
  python scripts/fastvideo_install

Standalone clone (skip submodule step):

  python scripts/fastvideo_install --path ~/src/FastVideo

Re-run is safe: submodule update (best effort) and patches are idempotent.
"""
from __future__ import annotations

import argparse
import os
import re
import shutil
import subprocess
import sys
from pathlib import Path

MARKER = "platform_system == 'Linux' and platform_machine == 'x86_64'"
KERNEL_DEP_RE = re.compile(
    r'^(\s*")fastvideo-kernel==([^"]+)(")\s*,?\s*$',
    re.MULTILINE,
)


def repo_root() -> Path:
    return Path(__file__).resolve().parents[1]


def recorded_submodule_commit(repo: Path, submodule_relpath: str) -> str | None:
    """Gitlink SHA the parent repo records for ``submodule_relpath`` (index or HEAD), or None."""
    for rev in (f"HEAD:{submodule_relpath}", f":{submodule_relpath}"):
        try:
            out = subprocess.run(
                ["git", "-C", str(repo), "rev-parse", rev],
                capture_output=True,
                text=True,
                check=True,
            )
            sha = out.stdout.strip()
            if len(sha) >= 7 and all(c in "0123456789abcdef" for c in sha.lower()):
                return sha
        except (subprocess.CalledProcessError, OSError):
            continue
    return None


def patch_pyproject(pyproject: Path) -> int:
    """Return 0 on success (including already patched), 1 on error."""
    text = pyproject.read_text(encoding="utf-8")

    def repl(m: re.Match[str]) -> str:
        return (
            f'{m.group(1)}fastvideo-kernel=={m.group(2)}; {MARKER}{m.group(3)},'
        )

    if "fastvideo-kernel==" not in text:
        print(
            f"Error: no fastvideo-kernel dependency in {pyproject} "
            "(unexpected FastVideo layout).",
            file=sys.stderr,
        )
        return 1

    for line in text.splitlines():
        if "fastvideo-kernel==" in line and "platform_system" in line:
            print(f"Already patched: {pyproject}")
            return 0

    new_text, n = KERNEL_DEP_RE.subn(repl, text, count=1)
    if n != 1:
        print(
            f"Error: could not patch fastvideo-kernel line in {pyproject}",
            file=sys.stderr,
        )
        return 1

    pyproject.write_text(new_text, encoding="utf-8")
    print(f"Patched {pyproject}")
    return 0


LTX2_DENOISING_OLD = """            with torch.autocast(
                    device_type="cuda",
                    dtype=target_dtype,
                    enabled=autocast_enabled,
            ), set_forward_context(
                    current_timestep=sigma.item(),
                    attn_metadata=attn_metadata,
                    forward_batch=batch,
            ):
"""

LTX2_DENOISING_NEW = """            # videofentanyl: MPS/CUDA-native autocast (upstream hard-coded cuda).
            _fv_ac_dev = latents.device.type
            _fv_ac_dtype = target_dtype
            _fv_ac_on = bool(autocast_enabled)
            if _fv_ac_dev != "cuda" and _fv_ac_dev != "mps":
                _fv_ac_on = False
            _fv_ac_device_type = _fv_ac_dev if _fv_ac_dev in ("cuda", "mps") else "cuda"
            _fv_ac_apply = _fv_ac_on and _fv_ac_dev in ("cuda", "mps")
            with torch.autocast(
                    device_type=_fv_ac_device_type,
                    dtype=_fv_ac_dtype,
                    enabled=_fv_ac_apply,
            ), set_forward_context(
                    current_timestep=sigma.item(),
                    attn_metadata=attn_metadata,
                    forward_batch=batch,
            ):
"""

# Older videofentanyl installs forced float16 under MPS autocast, which mismatched
# bf16 weights and triggered rms_norm Half vs BFloat16 warnings on Metal.
_LTX2_LEGACY_MPS_FP16_BLOCK = """            if _fv_ac_dev == "mps":
                # MPS autocast uses float16; weights stay bf16 where not under autocast.
                _fv_ac_dtype = torch.float16
            elif _fv_ac_dev != "cuda":
                _fv_ac_on = False"""

_LTX2_LEGACY_MPS_FP16_REPLACEMENT = """            if _fv_ac_dev != "cuda" and _fv_ac_dev != "mps":
                _fv_ac_on = False"""


# --- decoding.py: CPU batch.output for worker → parent mp.pipe ----------------------------

DECODING_CPU_MARKER = "videofentanyl: decoded frames CPU for mp.pipe"

DECODING_FRAMES_OLD = """        # Convert to float32 for compatibility
        frames = frames.to(torch.float32)

        # Crop padding if this is a LongCat refinement"""

DECODING_FRAMES_NEW = f"""        # {DECODING_CPU_MARKER} (MPS cannot _share_filename_).
        frames = frames.to(torch.float32).detach().cpu().contiguous()

        # Crop padding if this is a LongCat refinement"""


DECODING_VAE_CPU_MARKER = "videofentanyl: VAE output on CPU"

DECODING_DECODE_RETURN_OLD = """        # Normalize image to [0, 1] range
        image = (image / 2 + 0.5).clamp(0, 1)
        return image

    @torch.no_grad()
    def streaming_decode("""

DECODING_DECODE_RETURN_NEW = """        # Normalize image to [0, 1] range
        image = (image / 2 + 0.5).clamp(0, 1)
        # videofentanyl: VAE output on CPU before any IPC (MPS cannot _share_filename_).
        return image.to(torch.float32).detach().cpu().contiguous()

    @torch.no_grad()
    def streaming_decode("""

DECODING_STREAMING_RETURN_OLD = """        # Normalize image to [0, 1] range
        image = (image / 2 + 0.5).clamp(0, 1)
        assert cache is not None, "cache should not be None after streaming_decode"
        return image, cache

    @torch.no_grad()
    def forward("""

DECODING_STREAMING_RETURN_NEW = """        # Normalize image to [0, 1] range
        image = (image / 2 + 0.5).clamp(0, 1)
        assert cache is not None, "cache should not be None after streaming_decode"
        image = image.to(torch.float32).detach().cpu().contiguous()
        return image, cache

    @torch.no_grad()
    def forward("""


def patch_decoding_mps_ipc(decoding_py: Path) -> int:
    """CPU tensors for multiprocessing IPC: forward() batch.output + VAE returns."""
    if not decoding_py.is_file():
        print(f"Warning: {decoding_py} not found — skip decoding patch", file=sys.stderr)
        return 0
    text = decoding_py.read_text(encoding="utf-8")
    orig = text
    if DECODING_FRAMES_OLD in text:
        text = text.replace(DECODING_FRAMES_OLD, DECODING_FRAMES_NEW, 1)
        print(f"Patched {decoding_py} (forward CPU batch.output)")
    elif DECODING_CPU_MARKER not in text:
        print(
            f"Warning: expected float32 block not found in {decoding_py} — "
            "skip forward IPC patch",
            file=sys.stderr,
        )

    if DECODING_VAE_CPU_MARKER not in text:
        if DECODING_DECODE_RETURN_OLD in text:
            text = text.replace(DECODING_DECODE_RETURN_OLD, DECODING_DECODE_RETURN_NEW, 1)
        if DECODING_STREAMING_RETURN_OLD in text:
            text = text.replace(DECODING_STREAMING_RETURN_OLD, DECODING_STREAMING_RETURN_NEW, 1)
        if text != orig:
            print(f"Patched {decoding_py} (VAE decode/streaming_decode → CPU)")

    if text != orig:
        decoding_py.write_text(text, encoding="utf-8")
        return 0
    if DECODING_CPU_MARKER in text and DECODING_VAE_CPU_MARKER in text:
        print(f"Already patched: {decoding_py} (CPU decode for IPC)")
    return 0


# --- multiproc_executor.py: sanitize tensors before pipe.send ----------------------------

MULTIPROC_IPC_MARKER = "_tensor_for_worker_ipc_send"

MULTIPROC_SHALLOW_SANITIZE = """def _sanitize_worker_ipc_tensors(
    output_tensor: Any,
    extra: dict[str, Any],
) -> tuple[Any, dict[str, Any]]:
    if isinstance(output_tensor, torch.Tensor):
        output_tensor = _tensor_for_worker_ipc_send(output_tensor)
    cleaned: dict[str, Any] = {}
    for key, val in extra.items():
        if isinstance(val, torch.Tensor):
            cleaned[key] = _tensor_for_worker_ipc_send(val)
        else:
            cleaned[key] = val
    return output_tensor, cleaned

"""

MULTIPROC_DEEP_SANITIZE = """def _deep_ipc_safe(obj: Any) -> Any:
    \"\"\"Move every ``torch.Tensor`` to CPU for pickling (nested Mapping/list/tuple/dataclass).\"\"\"
    if isinstance(obj, torch.Tensor):
        return _tensor_for_worker_ipc_send(obj)
    if isinstance(obj, Mapping):
        return {k: _deep_ipc_safe(v) for k, v in obj.items()}
    if isinstance(obj, list):
        return [_deep_ipc_safe(v) for v in obj]
    if isinstance(obj, tuple):
        return tuple(_deep_ipc_safe(v) for v in obj)
    if is_dataclass(obj) and not isinstance(obj, type):
        return _deep_ipc_safe(asdict(obj))
    stages = getattr(obj, "stages", None)
    if stages is not None and isinstance(stages, Mapping) and type(obj).__name__ == "PipelineLoggingInfo":
        fresh = type(obj)()
        fresh.stages = _deep_ipc_safe(stages)
        return fresh
    return obj


def _sanitize_worker_ipc_tensors(
    output_tensor: Any,
    extra: dict[str, Any],
) -> tuple[Any, dict[str, Any]]:
    out = _deep_ipc_safe(output_tensor)
    ex = _deep_ipc_safe(extra)
    if not isinstance(ex, dict):
        ex = dict(extra or {})
    return out, ex

"""

MULTIPROC_SANITIZE_DEEP_ONLY = "def _sanitize_worker_ipc_tensors" + MULTIPROC_DEEP_SANITIZE.split(
    "def _sanitize_worker_ipc_tensors",
    1,
)[1]

# Older videofentanyl installs: dict-only ``_deep_ipc_safe`` (OrderedDict is a dict subclass,
# but ``PipelineLoggingInfo`` / nested metrics need Mapping + explicit logging wrapper).
MULTIPROC_DEEP_FN_LEGACY_A = """def _deep_ipc_safe(obj: Any) -> Any:
    \"\"\"Move every ``torch.Tensor`` (nested dict/list/tuple) to CPU for pickling.\"\"\"
    if isinstance(obj, torch.Tensor):
        return _tensor_for_worker_ipc_send(obj)
    if isinstance(obj, dict):
        return {k: _deep_ipc_safe(v) for k, v in obj.items()}
    if isinstance(obj, list):
        return [_deep_ipc_safe(v) for v in obj]
    if isinstance(obj, tuple):
        return tuple(_deep_ipc_safe(v) for v in obj)
    return obj


"""

MULTIPROC_DEEP_FN_LEGACY_B = """def _deep_ipc_safe(obj: Any) -> Any:
    \"\"\"Move every ``torch.Tensor`` (including nested dict/list/tuple) to CPU for pickling.\"\"\"
    if isinstance(obj, torch.Tensor):
        return _tensor_for_worker_ipc_send(obj)
    if isinstance(obj, dict):
        return {k: _deep_ipc_safe(v) for k, v in obj.items()}
    if isinstance(obj, list):
        return [_deep_ipc_safe(v) for v in obj]
    if isinstance(obj, tuple):
        return tuple(_deep_ipc_safe(v) for v in obj)
    return obj


"""

MULTIPROC_HELPERS = '''
def _tensor_for_worker_ipc_send(t: torch.Tensor) -> torch.Tensor:
    """Prepare tensors for ``multiprocessing.Connection.send`` from a worker.

    CUDA uses dedicated pickling reductions; CPU is trivially shareable.  MPS
    (and other non-CUDA accelerators) otherwise hit
    ``RuntimeError: _share_filename_: only available on CPU``.
    """
    if t.device.type in ("cpu", "cuda"):
        return t
    return t.detach().cpu().contiguous()


''' + MULTIPROC_DEEP_SANITIZE

MULTIPROC_SEND_OLD = """                        result = output_batch.output
                        extra = output_batch.extra or {}
                        extra["peak_memory_mb"] = (torch.cuda.max_memory_allocated() / (1024 * 1024))
                        self.pipe.send({
                            "output_batch": result,
                            "logging_info": logging_info,
                            "extra": extra,
                        })"""

# Patched send without wrapping ``logging_info`` (fails if stage metrics hold tensors).
MULTIPROC_SEND_BARE = """                        result = output_batch.output
                        extra = dict(output_batch.extra or {})
                        extra["peak_memory_mb"] = (torch.cuda.max_memory_allocated() / (1024 * 1024))
                        result, extra = _sanitize_worker_ipc_tensors(result, extra)
                        self.pipe.send({
                            "output_batch": result,
                            "logging_info": logging_info,
                            "extra": extra,
                        })"""

MULTIPROC_SEND_WRAPPED = """                        result = output_batch.output
                        extra = dict(output_batch.extra or {})
                        extra["peak_memory_mb"] = (torch.cuda.max_memory_allocated() / (1024 * 1024))
                        result, extra = _sanitize_worker_ipc_tensors(result, extra)
                        self.pipe.send(
                            _deep_ipc_safe({
                                "output_batch": result,
                                "logging_info": logging_info,
                                "extra": extra,
                            }),
                        )"""


def _multiproc_ensure_ipc_imports(text: str) -> str:
    """Ensure ``Mapping`` / ``asdict`` / ``is_dataclass`` are importable for ``_deep_ipc_safe``."""
    if "Callable, Mapping" not in text and "from collections.abc import Callable\n" in text:
        text = text.replace(
            "from collections.abc import Callable\n",
            "from collections.abc import Callable, Mapping\n",
            1,
        )
    if "asdict, dataclass, is_dataclass" not in text and "from dataclasses import dataclass\n" in text:
        text = text.replace(
            "from dataclasses import dataclass\n",
            "from dataclasses import asdict, dataclass, is_dataclass\n",
            1,
        )
    return text


def patch_multiproc_executor_mps_ipc(multiproc_py: Path) -> int:
    """Sanitize worker RPC payloads so MPS tensors are not pickled on pipes."""
    if not multiproc_py.is_file():
        print(f"Warning: {multiproc_py} not found — skip multiproc IPC patch", file=sys.stderr)
        return 0
    text = multiproc_py.read_text(encoding="utf-8")
    orig = text

    if MULTIPROC_SHALLOW_SANITIZE in text:
        text = text.replace(MULTIPROC_SHALLOW_SANITIZE, MULTIPROC_SANITIZE_DEEP_ONLY, 1)
        text = _multiproc_ensure_ipc_imports(text)

    for legacy in (MULTIPROC_DEEP_FN_LEGACY_A, MULTIPROC_DEEP_FN_LEGACY_B):
        if legacy in text:
            text = text.replace(legacy, MULTIPROC_DEEP_SANITIZE.split("def _sanitize_worker_ipc_tensors", 1)[0], 1)
            text = _multiproc_ensure_ipc_imports(text)
            break

    if MULTIPROC_SEND_BARE in text:
        text = text.replace(MULTIPROC_SEND_BARE, MULTIPROC_SEND_WRAPPED, 1)

    if text != orig:
        multiproc_py.write_text(text, encoding="utf-8")
        print(f"Upgraded {multiproc_py} (MPS worker IPC)")
        return 0

    if MULTIPROC_IPC_MARKER in text:
        if (
            "isinstance(obj, Mapping)" in text
            and "_deep_ipc_safe({" in text
            and MULTIPROC_SHALLOW_SANITIZE not in text
        ):
            print(f"Already patched: {multiproc_py} (MPS worker IPC)")
            return 0
        print(
            f"Warning: {multiproc_py} has partial IPC helpers — expected Mapping-based "
            "`_deep_ipc_safe` and wrapped `pipe.send`; skip further multiproc IPC patch",
            file=sys.stderr,
        )
        return 0

    if MULTIPROC_SEND_OLD not in text:
        print(
            f"Warning: expected execute_forward pipe.send block not found in {multiproc_py} — "
            "skip multiproc IPC patch",
            file=sys.stderr,
        )
        return 0

    anchors_inserts = (
        (
            "logger = init_logger(__name__)\n\n\ndef _make_queue_log_handler",
            "logger = init_logger(__name__)\n\n\n" + MULTIPROC_HELPERS + "def _make_queue_log_handler",
        ),
        (
            "logger = init_logger(__name__)\n\ndef _make_queue_log_handler",
            "logger = init_logger(__name__)\n\n" + MULTIPROC_HELPERS + "def _make_queue_log_handler",
        ),
    )
    for anchor, insert in anchors_inserts:
        if anchor in text:
            text = text.replace(anchor, insert, 1)
            break
    else:
        print(
            f"Warning: could not find logger anchor before _make_queue_log_handler in {multiproc_py} — "
            "skip multiproc IPC patch",
            file=sys.stderr,
        )
        return 0

    text = text.replace(MULTIPROC_SEND_OLD, MULTIPROC_SEND_WRAPPED, 1)
    text = _multiproc_ensure_ipc_imports(text)
    multiproc_py.write_text(text, encoding="utf-8")
    print(f"Patched {multiproc_py} (MPS-safe worker IPC)")
    return 0


# --- ltx2_denoising.py: FV_PROGRESS_JSON lines (after MPS autocast patch) ------------------

LTX2_PROGRESS_MARKER = (
    "videofentanyl: denoise step progress (FV_PROGRESS_JSON for videofentanylserver)"
)

LTX2_PROGRESS_IMPORTS_OLD = """import math
import os

import torch"""

LTX2_PROGRESS_IMPORTS_NEW = """import math
import json
import os
import time

import torch"""

LTX2_PROGRESS_LOOP_OLD = """        use_vsa = (vsa_available and envs.FASTVIDEO_ATTENTION_BACKEND == "VIDEO_SPARSE_ATTN")
        vsa_metadata_builder = (VideoSparseAttentionMetadataBuilder() if use_vsa else None)

        for step_index in tqdm(range(len(sigmas) - 1)):"""

LTX2_PROGRESS_LOOP_NEW = """        use_vsa = (vsa_available and envs.FASTVIDEO_ATTENTION_BACKEND == "VIDEO_SPARSE_ATTN")
        vsa_metadata_builder = (VideoSparseAttentionMetadataBuilder() if use_vsa else None)

        # videofentanyl: denoise step progress (FV_PROGRESS_JSON for videofentanylserver)
        _n_steps = len(sigmas) - 1
        _loop_t0 = time.perf_counter()
        _prev = _loop_t0
        _step_dts: list[float] = []

        for step_index in tqdm(range(_n_steps), desc="Denoising"):"""

LTX2_PROGRESS_TAIL_OLD = """                audio_latents = (audio_latents.float() + audio_velocity.float() * dt).to(audio_latents.dtype)

        batch.latents = latents
        batch.extra["ltx2_audio_latents"] = audio_latents"""

LTX2_PROGRESS_TAIL_NEW = """                audio_latents = (audio_latents.float() + audio_velocity.float() * dt).to(audio_latents.dtype)

            # videofentanyl: structured denoise progress (parsed by videofentanylserver)
            _now = time.perf_counter()
            _dt = _now - _prev
            _prev = _now
            _step_dts.append(_dt)
            _win = _step_dts[-max(1, min(len(_step_dts), 8)) :]
            _avg = sum(_win) / len(_win)
            _remaining = _n_steps - step_index - 1
            _eta = _avg * _remaining
            logger.info(
                "FV_PROGRESS_JSON %s",
                json.dumps(
                    {
                        "stage": "denoise",
                        "step": step_index + 1,
                        "total": _n_steps,
                        "elapsed_s": round(_now - _loop_t0, 2),
                        "last_step_s": round(_dt, 3),
                        "avg_step_s": round(_avg, 3),
                        "eta_s": round(_eta, 1),
                    },
                    separators=(",", ":"),
                ),
            )

        batch.latents = latents
        batch.extra["ltx2_audio_latents"] = audio_latents"""


def patch_ltx2_denoising_progress(denoising_py: Path) -> int:
    """Emit FV_PROGRESS_JSON log lines each denoise step (idempotent)."""
    if not denoising_py.is_file():
        print(f"Warning: {denoising_py} not found — skip denoise progress patch", file=sys.stderr)
        return 0
    text = denoising_py.read_text(encoding="utf-8")
    if LTX2_PROGRESS_MARKER in text or "FV_PROGRESS_JSON" in text:
        print(f"Already patched: {denoising_py} (FV_PROGRESS_JSON)")
        return 0
    if LTX2_PROGRESS_IMPORTS_OLD in text:
        text = text.replace(LTX2_PROGRESS_IMPORTS_OLD, LTX2_PROGRESS_IMPORTS_NEW, 1)
    elif "import json" not in text:
        print(
            f"Warning: could not insert json/time imports in {denoising_py} — "
            "skip denoise progress patch",
            file=sys.stderr,
        )
        return 0
    if LTX2_PROGRESS_LOOP_OLD not in text:
        print(
            f"Warning: expected denoise ``for`` / vsa block not found in {denoising_py} — "
            "skip denoise progress patch",
            file=sys.stderr,
        )
        return 0
    text = text.replace(LTX2_PROGRESS_LOOP_OLD, LTX2_PROGRESS_LOOP_NEW, 1)
    if LTX2_PROGRESS_TAIL_OLD not in text:
        print(
            f"Warning: expected denoise loop tail not found in {denoising_py} — "
            "skip denoise progress patch (partial edit?)",
            file=sys.stderr,
        )
        return 0
    text = text.replace(LTX2_PROGRESS_TAIL_OLD, LTX2_PROGRESS_TAIL_NEW, 1)
    denoising_py.write_text(text, encoding="utf-8")
    print(f"Patched {denoising_py} (FV_PROGRESS_JSON denoise progress)")
    return 0


def patch_ltx2_denoising_mps(denoising_py: Path) -> int:
    """Patch LTX2 denoising autocast for MPS (idempotent). Returns 0 on success."""
    marker = "videofentanyl: MPS/CUDA-native autocast"
    if not denoising_py.is_file():
        print(f"Warning: {denoising_py} not found — skip denoising patch", file=sys.stderr)
        return 0
    text = denoising_py.read_text(encoding="utf-8")
    if marker in text:
        if _LTX2_LEGACY_MPS_FP16_BLOCK in text:
            text = text.replace(
                _LTX2_LEGACY_MPS_FP16_BLOCK,
                _LTX2_LEGACY_MPS_FP16_REPLACEMENT,
                1,
            )
            denoising_py.write_text(text, encoding="utf-8")
            print(
                f"Upgraded {denoising_py}: MPS autocast dtype now follows target_dtype "
                "(fixes Half/BFloat16 rms_norm mismatch vs old float16 override).",
                flush=True,
            )
            return 0
        print(f"Already patched: {denoising_py}")
        return 0
    if LTX2_DENOISING_OLD not in text:
        print(
            f"Warning: expected autocast block not found in {denoising_py} — "
            "upstream layout may have changed; skip denoising patch",
            file=sys.stderr,
        )
        return 0
    denoising_py.write_text(text.replace(LTX2_DENOISING_OLD, LTX2_DENOISING_NEW, 1), encoding="utf-8")
    print(f"Patched {denoising_py} (MPS/CUDA autocast)")
    return 0



# --- LTX2 image-to-video (image_path / pil_image first-frame anchor) -------------------------

